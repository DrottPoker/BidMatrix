# BidMatrix runtime
BIDMATRIX_ENVIRONMENT=Development
BIDMATRIX_PUBLIC_BASE_URL=http://localhost:3000
BIDMATRIX_INTERNAL_BASE_URL=http://api:8080

# Application PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXPOSED_PORT=55432
POSTGRES_DATABASE=bidmatrix
POSTGRES_USER=bidmatrix_app
POSTGRES_PASSWORD=change-me-local-postgres

# S3-compatible object storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_QUARANTINE=bidmatrix-quarantine
S3_BUCKET_PRIVATE=bidmatrix-private
S3_ACCESS_KEY=bidmatrix-local
S3_SECRET_KEY=change-me-local-storage

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=bidmatrix-agents

# Models are optional in Development. Empty means deterministic fake mode.
OPENAI_API_KEY=
OPENAI_MODEL_EXECUTIVE=
OPENAI_MODEL_SUPPORT=
OPENAI_MODEL_PRODUCT=
OPENAI_MODEL_ENGINEERING=
OPENAI_AGENTS_DISABLE_TRACING=1
OPENAI_AGENTS_DONT_LOG_MODEL_DATA=1
OPENAI_AGENTS_DONT_LOG_TOOL_DATA=1

# Development bootstrap placeholders
INTERNAL_SERVICE_TOKEN=change-me-local-internal-token
OWNER_BOOTSTRAP_EMAIL=owner@example.invalid
OWNER_BOOTSTRAP_PASSWORD=change-me-local-owner-password
